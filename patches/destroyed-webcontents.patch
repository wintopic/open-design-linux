+export type WebContentsUrlSurface = {
+  getURL: () => string;
+  isDestroyed: () => boolean;
+};
+
+/**
+ * Reads the current renderer URL only while Electron still considers the
+ * WebContents usable. Destruction can race the check, so getURL itself must
+ * remain inside the guard as well.
+ */
+export function getLiveWebContentsUrl(webContents: WebContentsUrlSurface): string | null {
+  if (webContents.isDestroyed()) return null;
+  try {
+    return webContents.getURL();
+  } catch {
+    return null;
+  }
+}
